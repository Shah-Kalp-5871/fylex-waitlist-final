// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Waitlist {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  phone      String   @unique
  created_at DateTime @default(now())
}

model Vote {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  ip         String   @unique      // one vote per IP address
  watchId    Int                   // 1=OliveGreen, 2=DarkBlue, 3=Silver, 4=Gold
  created_at DateTime @default(now())
}
